{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@workspace/config": "workspace:*",
    "@workspace/validation": "workspace:*",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.5",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@types/node": "^25.1.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": "./src/index.ts",
    "./queries": "./src/queries.ts",
    "./schema": "./src/schema.ts",
    "./seed": "./src/seed.ts"
  }
}
